generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CITOYEN
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(CITOYEN)
  firstName    String
  lastName     String
  avatarUrl    String?
  interests    String[] @default([])
  createdAt    DateTime @default(now())

  memberships    GroupMember[]
  messages       Message[]
  outings        Outing[]
  participations OutingParticipant[]
  pollVotes      OutingPollVote[]
}

model Group {
  id            String   @id @default(cuid())
  name          String
  lieu          String
  maxMembers    Int      @default(4)
  sessionNumber Int      @default(1)
  baseGroupId   String?
  createdAt     DateTime @default(now())

  baseGroup Group?  @relation("GroupSessions", fields: [baseGroupId], references: [id])
  sessions  Group[] @relation("GroupSessions")

  members  GroupMember[]
  messages Message[]
  outings  Outing[]
}

model GroupMember {
  id       String   @id @default(cuid())
  userId   String
  groupId  String
  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  group Group @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId])
}

model Message {
  id       String      @id @default(cuid())
  groupId  String
  userId   String
  type     MessageType @default(TEXT)
  content  String?
  outingId String?
  sentAt   DateTime    @default(now())

  group  Group   @relation(fields: [groupId], references: [id])
  user   User    @relation(fields: [userId], references: [id])
  outing Outing? @relation(fields: [outingId], references: [id])
}

enum MessageType {
  TEXT
  OUTING
  JOIN
}

enum ParticipationStatus {
  ACCEPTED
  REFUSED
}

model Outing {
  id           String   @id @default(cuid())
  title        String
  date         DateTime
  location     String
  maxSpots     Int      @default(3)
  groupId      String
  userId       String
  recurring    Boolean  @default(false)
  hasPoll      Boolean  @default(false)
  createdAt    DateTime @default(now())

  group        Group              @relation(fields: [groupId], references: [id])
  user         User               @relation(fields: [userId], references: [id])
  participants OutingParticipant[]
  pollOptions  OutingPollOption[]
  messages     Message[]
}

model OutingParticipant {
  id       String              @id @default(cuid())
  outingId String
  userId   String
  status   ParticipationStatus
  joinedAt DateTime            @default(now())

  outing Outing @relation(fields: [outingId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([outingId, userId])
}

model OutingPollOption {
  id       String   @id @default(cuid())
  outingId String
  dateTime DateTime

  outing Outing           @relation(fields: [outingId], references: [id])
  votes  OutingPollVote[]
}

model OutingPollVote {
  id       String @id @default(cuid())
  optionId String
  userId   String

  option OutingPollOption @relation(fields: [optionId], references: [id])
  user   User             @relation(fields: [userId], references: [id])

  @@unique([optionId, userId])
}
